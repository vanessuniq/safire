# Safire Demo App Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Session Secret (required)
# ============================================
# Generate with: ruby -e "require 'securerandom'; puts SecureRandom.hex(32)"
SESSION_SECRET=your_session_secret_here

# ============================================
# Asymmetric Client Authentication (optional)
# ============================================
# These are CLIENT-level credentials (same for all FHIR servers).
# For confidential asymmetric authentication (private_key_jwt).

# Private Key in PEM format
# Generate RSA key: openssl genrsa -out private_key.pem 2048
# Generate EC key:  openssl ecparam -name secp384r1 -genkey -noout -out private_key.pem
#
# Paste the contents of your private key file here (include the BEGIN/END lines):
ASYMMETRIC_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----
...your private key content here...
-----END RSA PRIVATE KEY-----"

# Key ID (kid)
# This must match the kid in your registered JWKS with the authorization server.
# Use a unique identifier like a UUID or a descriptive name.
ASYMMETRIC_KID=my-app-key-001

# ============================================
# Notes on Asymmetric Authentication
# ============================================
#
# 1. The app automatically serves your public key at:
#    http://localhost:PORT/.well-known/jwks.json
#
# 2. Register your app with the FHIR server's authorization server:
#    - Provide your JWKS URL (the above endpoint)
#    - Or upload your public key directly
#
# 3. Extract your public key from the private key:
#    openssl rsa -in private_key.pem -pubout -out public_key.pem
#
# 4. The app supports both RSA (RS384) and EC P-384 (ES384) keys.
#
# 5. For production, use HTTPS for your JWKS endpoint.
#    Authorization servers may reject HTTP URLs.
