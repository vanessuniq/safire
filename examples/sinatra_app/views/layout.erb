<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Safire Demo</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= File.mtime(File.join(settings.public_folder, 'css', 'style.css')).to_i %>">
  <script src="/js/app.js?v=<%= File.mtime(File.join(settings.public_folder, 'js', 'app.js')).to_i %>" defer></script>
</head>
<body>
  <header>
    <nav>
      <a href="/" class="logo">Safire Demo</a>
      <form action="/reset-session" method="post" class="nav-form">
        <button type="submit" class="btn-nav">Reset Session</button>
      </form>
    </nav>
  </header>

  <main>
    <% if @flash[:message] %>
      <div class="flash flash-<%= h(@flash[:type]) %>">
        <%= h(@flash[:message]) %>
      </div>
    <% end %>

    <%= yield %>
  </main>

  <footer>
    <p>Powered by <a href="https://github.com/vanessuniq/safire" target="_blank">Safire</a> - SMART & UDAP Ruby Client</p>
  </footer>
</body>
</html>
